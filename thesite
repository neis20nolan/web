<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Мой сайт</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #4facfe, #00f2fe);
            color: white;
            text-align: center;
        }

        .container {
            padding-top: 100px;
        }

        h1 {
            font-size: 3em;
        }

        p {
            font-size: 1.3em;
        }

        button {
            padding: 15px 30px;
            font-size: 18px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            background: white;
            color: #0077ff;
            transition: 0.2s;
        }

        button:hover {
            transform: scale(1.05);
        }

        #counter {
            font-size: 2em;
            margin-top: 20px;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Привет!</h1>
    <p>Это мой первый сайт.</p>

    <button onclick="clickMe()">Нажми меня</button>

    <div id="counter">0</div>
</div>

<script>
let count = 0;

function clickMe() {
    count++;
    document.getElementById("counter").textContent = count;

    if (count === 10) {
        alert("Уже 10 кликов!");
    }
}
</script>

</body>
</html>
